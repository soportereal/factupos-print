<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8fafc">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo / Titulo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FactuPOS Print"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1e293b"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Puente de impresion multi-destino"
            android:textSize="14sp"
            android:textColor="#64748b"
            android:layout_marginTop="4dp" />

        <!-- Card Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado del servicio"
                android:textSize="12sp"
                android:textColor="#94a3b8"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/txtEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detenido"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#ef4444"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card Impresora Activa -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Impresora activa"
                android:textSize="12sp"
                android:textColor="#94a3b8"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/txtImpresora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1e293b"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card Puerto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servidor HTTP"
                android:textSize="12sp"
                android:textColor="#94a3b8"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/txtPuerto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="16sp"
                android:textColor="#1e293b"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card Selector de Impresoras -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/txtPrinterLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Impresoras disponibles"
                android:textSize="12sp"
                android:textColor="#94a3b8"
                android:textAllCaps="true" />

            <RadioGroup
                android:id="@+id/radioGroupPrinters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mantén presionada una impresora BT para cambiar su protocolo (Auto / ESC-POS / CPCL / ZPL)."
                android:textSize="11sp"
                android:textColor="#64748b"
                android:fontFamily="sans-serif"
                android:textStyle="italic"
                android:layout_marginTop="10dp"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnIniciar"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Iniciar"
                android:textColor="#ffffff"
                android:backgroundTint="#22c55e"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnDetener"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Detener"
                android:textColor="#ffffff"
                android:backgroundTint="#ef4444"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp" />

            <Button
                android:id="@+id/btnPrueba"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Prueba"
                android:textColor="#ffffff"
                android:backgroundTint="#3b82f6"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Card Log de Prints -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Log de impresión"
                    android:textSize="12sp"
                    android:textColor="#94a3b8"
                    android:textAllCaps="true" />

                <Button
                    android:id="@+id/btnLimpiarLog"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Limpiar"
                    android:textSize="10sp"
                    android:textColor="#ffffff"
                    android:backgroundTint="#64748b"
                    android:minWidth="0dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/scrollLog"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginTop="8dp"
                android:background="#0f172a"
                android:padding="8dp">

                <TextView
                    android:id="@+id/txtPrintLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="(esperando prints...)"
                    android:textColor="#a3e635"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true" />
            </ScrollView>
        </LinearLayout>

        <!-- Instrucciones -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Esta app corre un servidor HTTP en localhost:8765 que permite a Chrome enviar tiquetes a la impresora seleccionada (SUNMI interna o Bluetooth pareada)."
            android:textSize="12sp"
            android:textColor="#94a3b8"
            android:textAlignment="center"
            android:layout_marginTop="20dp"
            android:lineSpacingMultiplier="1.4" />

        <!-- Versión y fecha -->
        <TextView
            android:id="@+id/txtVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textSize="24sp"
            android:textColor="#3b82f6"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
