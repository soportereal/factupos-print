    # ---------- helpers del menú Inicio (Windows 2000) ----------
    def _mitem(self, label, icon, on_click, arrow=False):
        b = Gtk.Button()
        b.set_relief(Gtk.ReliefStyle.NONE)
        b.get_style_context().add_class("fp-mitem")
