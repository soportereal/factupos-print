#!/bin/bash
set -e
for home in /root /home/*; do
    for desk in "$home/Desktop" "$home/Escritorio"; do
        rm -f "$desk/factupos-fingerprint-kiosko.desktop" 2>/dev/null || true
    done
done
rm -f /etc/sudoers.d/factupos-fingerprint-kiosko 2>/dev/null || true
update-desktop-database /usr/share/applications 2>/dev/null || true
exit 0
